{
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -S . -B build",
            "group": "build",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build build -j$(nproc)",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": "CMake Configure"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}